{
  "manifest_version": 3,
  "name": "FreeTube Redirect",
  "version": "1.0.0",
  "description": "Aggiunge un pulsante sotto i video di YouTube per aprirli direttamente in FreeTube",
  "permissions": ["activeTab"],
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "FreeTube Redirect"
  }
}
